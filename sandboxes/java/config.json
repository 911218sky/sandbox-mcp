{
	"id": "java",
	"name": "Java",
	"description": "Compile and run Java code in an isolated sandbox. Supports Java preview features.",
	"hints": {
		"isDestructive": false,
		"isIdempotent": true
	},
	"version": "0.1.0",
	"image": "sandbox-mcp/java:latest",
	"user": "sandbox",
	"entrypoint": "Main.java",
	"timeout": 60,
	"command": [
		"sh",
		"-c",
		"javac --enable-preview --source 21 -d /tmp *.java && java --enable-preview -cp /tmp Main"
	],
	"parameters": {
		"additionalFiles": true
	},
	"security": {
		"readOnly": false,
		"capDrop": [
			"all"
		],
		"securityOpt": [
			"no-new-privileges:true"
		],
		"network": "none"
	},
	"resources": {
		"cpu": 1,
		"memory": 256,
		"processes": 64,
		"files": 96
	},
	"mount": {
		"workdir": "/sandbox",
		"tmpdirPrefix": "sandbox-mcp-",
		"scriptPerms": "0755",
		"readOnly": false
	}
}
